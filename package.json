{
    "name": "textlint-plugin-org",
    "version": "0.3.5",
    "description": "Textlint plugin for Org mode",
    "repository": {
        "type": "git",
        "url": "git@github.com:kijimaD/textlint-plugin-org.git"
    },
    "author": "Kijima Daigo",
    "license": "GPLv3",
    "bugs": {
        "url": "https://github.com/kijimaD/textlint-plugin-org/issues"
    },
    "homepage": "https://github.com/kijimaD/textlint-plugin-org#readme",
    "main": "lib/index.js",
    "files": [
        "lib",
        "src"
    ],
    "directories": {
        "test": "test"
    },
    "scripts": {
        "build": "tsc -b && tsc -b tsconfig.json",
        "prepublish": "npm run --if-present build",
        "test": "tsx --test",
        "watch": "tsc -b --watch",
        "lint": "npx eslint src/**/*.ts"
    },
    "dependencies": {
        "@textlint/ast-node-types": "^15.6.0",
        "orga": "2.4.9",
        "structured-source": "^4.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@textlint/ast-tester": "^15.6.0",
        "@textlint/kernel": "^15.6.0",
        "@types/node": "^25.6.0",
        "@types/traverse": "^0.6.37",
        "@typescript-eslint/eslint-plugin": "^8.59.2",
        "@typescript-eslint/parser": "^8.59.2",
        "eslint": "^10.3.0",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import-x": "^4.16.2",
        "globals": "^17.6.0",
        "textlint-rule-max-comma": "^4.0.0",
        "traverse": "^0.6.11",
        "ts-node": "^10.9.2",
        "ts-node-test-register": "^10.0.0",
        "tsx": "^4.21.0",
        "typescript": "^5.0.2",
        "typescript-eslint": "^8.59.2"
    }
}
